const mongoose = require("mongoose")

const user_schema = mongoose.Schema({

    first_name: {
        type: String,
        required: true,
        trim: true
    },

    last_name: {
        type: String,
        required: true,
        trim: true
    },

    email: {
        type: String,
        required: true,
        unique: true,
        lowercase: true
    },

    password: {
        type: String,
        required: true,
        minlength: 6
    }

})

const user = mongoose.model("user", user_schema)

module.exports = user